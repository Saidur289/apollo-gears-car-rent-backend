              "listen": "prerequest",
              "script": {
                "exec": [
                  "const token = pm.environment.get('accessToken');",
                  "if (!token) {",
                  "    console.warn('No access token found. Please login first.');",
                  "} else {",
                  "    pm.request.headers.add({",
                  "        key: 'Authorization',",
                  "        value: 'Bearer ' + token",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/bids/{{bidId}}",
              "host": ["{{baseUrl}}"],
              "path": ["bids", "{{bidId}}"]
            }
          }
        }
      ]
    },
